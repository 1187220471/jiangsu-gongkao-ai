generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  password         String
  nickname         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  coins            Int       @default(0)
  dailyFreeCount   Int       @default(5)
  freeCountResetAt DateTime  @default(now())
  accessExpire     DateTime?
  accessLevel      String    @default("none")
  recentTopics     String[]  @default([])
  records          Record[]
}

model Record {
  id              String   @id @default(uuid())
  userId          String
  questionType    String
  question        String
  referenceAnswer String?
  userAnswer      String?
  evaluation      String?
  improvedAnswer  String?
  score           Int?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvitationCode {
  id        String    @id @default(uuid())
  code      String    @unique
  type      String    @default("month")
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  content   String
  type      String   @default("其他")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyNews {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  topNews   String
  allNews   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("daily_news")
}

model CronExecutionLog {
  id        String   @id @default(uuid())
  jobName   String
  status    String
  message   String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([jobName, createdAt])
}

// 真题复盘模块
model ZhentiQuestion {
  id              Int      @id @default(autoincrement())
  examTitle       String   // 考试场次，如"2024年3月9日江苏省考面试题（A类）"
  examYear        Int      // 年份，如 2024
  examDate        String   // 日期字符串，如"2024-03-09"
  examCategory    String?  // 类别：A类/B类/C类/公安系统/无锡等
  questionNumber  Int      // 第几题
  questionText    String   // 题目原文
  questionType    String   @default("未分类") // 题型（社会现象/组织管理等）
  answer1         String   // temperature=0.9 的答案
  answer2         String   // temperature=0.7 的答案
  answer3         String   // temperature=0.5 的答案
  score1          Int      // 答案1得分
  score2          Int      // 答案2得分
  score3          Int      // 答案3得分
  comparison      String   // 评分对比JSON（字符串存储）
  finalAnswer     String   // 汇总版参考答案
  finalWordCount  Int      @default(0)
  imageUrl        String?  // 题目配图URL（漫画/图表/照片等）
  createdAt       DateTime @default(now())
  bookmarks       ZhentiBookmark[]

  @@index([examYear])
  @@index([examDate])
  @@index([examDate, examCategory])
  @@map("zhenti_question")
}

model ZhentiBookmark {
  id          Int      @id @default(autoincrement())
  userId      String
  questionId  Int
  proficiency String   @default("weak") // weak / okay / mastered
  notes       String?
  createdAt   DateTime @default(now())
  question    ZhentiQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("zhenti_bookmark")
}
