generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  password         String
  nickname         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  coins            Int       @default(0)
  dailyFreeCount   Int       @default(5)
  freeCountResetAt DateTime  @default(now())
  accessExpire     DateTime?
  accessLevel      String    @default("none")
  recentTopics     String[]  @default([])
  records          Record[]
}

model Record {
  id              String   @id @default(uuid())
  userId          String
  questionType    String
  question        String
  referenceAnswer String?
  userAnswer      String?
  evaluation      String?
  improvedAnswer  String?
  score           Int?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvitationCode {
  id        String    @id @default(uuid())
  code      String    @unique
  type      String    @default("month")
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  content   String
  type      String   @default("其他")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyNews {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  topNews   String
  allNews   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("daily_news")
}

model CronExecutionLog {
  id        String   @id @default(uuid())
  jobName   String
  status    String
  message   String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([jobName, createdAt])
}
