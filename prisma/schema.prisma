generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  password         String
  nickname         String?
  openid           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  coins            Int       @default(0)
  dailyFreeCount   Int       @default(5)
  freeCountResetAt DateTime  @default(now())
  accessExpire     DateTime?
  accessLevel      String    @default("none")
  recentTopics     String[]  @default([])
  records          Record[]
  userPoints       UserPoints?
  userCollections  UserCollection[]
  focusSessions    FocusSession[]
}

model Record {
  id              String   @id @default(uuid())
  userId          String
  questionType    String
  question        String
  referenceAnswer String?
  userAnswer      String?
  evaluation      String?
  improvedAnswer  String?
  score           Int?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvitationCode {
  id        String    @id @default(uuid())
  code      String    @unique
  type      String    @default("month")
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model BindToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("bind_token")
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  content   String
  type      String   @default("其他")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyNews {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  topNews   String
  allNews   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("daily_news")
}

model CronExecutionLog {
  id        String   @id @default(uuid())
  jobName   String
  status    String
  message   String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([jobName, createdAt])
}

// 真题复盘模块
model ZhentiQuestion {
  id              Int      @id @default(autoincrement())
  examTitle       String   // 考试场次，如"2024年3月9日江苏省考面试题（A类）"
  examYear        Int      // 年份，如 2024
  examDate        String   // 日期字符串，如"2024-03-09"
  examCategory    String?  // 类别：A类/B类/C类/公安系统/无锡等
  questionNumber  Int      // 第几题
  questionText    String   // 题目原文
  questionType    String   @default("未分类") // 题型（社会现象/组织管理等）
  answer1         String   // temperature=0.9 的答案
  answer2         String   // temperature=0.7 的答案
  answer3         String   // temperature=0.5 的答案
  score1          Int      // 答案1得分
  score2          Int      // 答案2得分
  score3          Int      // 答案3得分
  comparison      String   // 评分对比JSON（字符串存储）
  finalAnswer     String   // 汇总版参考答案
  finalWordCount  Int      @default(0)
  imageUrl        String?  // 题目配图URL（漫画/图表/照片等）
  createdAt       DateTime @default(now())
  bookmarks       ZhentiBookmark[]

  @@index([examYear])
  @@index([examDate])
  @@index([examDate, examCategory])
  @@map("zhenti_question")
}

model ZhentiBookmark {
  id          Int      @id @default(autoincrement())
  userId      String
  questionId  Int
  proficiency String   @default("weak") // weak / okay / mastered
  notes       String?
  createdAt   DateTime @default(now())
  question    ZhentiQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("zhenti_bookmark")
}

// 申论真题答案参考模块
model ShenlunQuestion {
  id              Int      @id @default(autoincrement())
  examTitle       String   // 考试场次，如"2025年江苏省公考《申论》题（A卷）"
  examYear        Int      // 年份，如 2025
  examDate        String   // 日期字符串，如"2025-12-08"（无精确日期时使用年份）
  examCategory    String   // 类别：A / B / C
  questionNumber  Int      // 第几题
  questionText    String   // 题目原文
  questionType    String   @default("未分类") // 题型（归纳概括/综合分析/贯彻执行等）
  score           Int?     // 分值
  wordLimit       String?  // 字数要求，如"不超过250字"
  materialRange   String?  // 材料范围，如"给定资料1-4"
  referenceAnswer String?  // 官方参考答案（如有）
  createdAt       DateTime @default(now())
  materials       ShenlunMaterial[]
  answers         ShenlunTeacherAnswer[]
  bookmarks       ShenlunBookmark[]

  @@unique([examYear, examCategory, questionNumber])
  @@index([examYear])
  @@index([examDate])
  @@index([examDate, examCategory])
  @@map("shenlun_question")
}

model ShenlunMaterial {
  id            Int    @id @default(autoincrement())
  questionId    Int
  materialNum   String // 材料编号，如 "1"、"2"
  content       String // 材料原文
  materialOrder Int    @default(0)
  question      ShenlunQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("shenlun_material")
}

model ShenlunTeacherAnswer {
  id          Int    @id @default(autoincrement())
  questionId  Int
  teacherName String // 某笔/某站/唐棣/林峰等
  answerText  String // 答案原文
  answerOrder Int    @default(0) // 展示顺序
  question    ShenlunQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("shenlun_teacher_answer")
}

model ShenlunBookmark {
  id          Int      @id @default(autoincrement())
  userId      String
  questionId  Int
  proficiency String   @default("weak") // weak / okay / mastered
  notes       String?
  createdAt   DateTime @default(now())
  question    ShenlunQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("shenlun_bookmark")
}

// 学习点 + 抽卡集卡系统
model UserPoints {
  userId      String   @id
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model PointsLog {
  id        Int      @id @default(autoincrement())
  userId    String
  amount    Int
  type      String // answer / set / zhenti / shenlun / focus / dailySign / draw / drawRepeat / share
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("points_log")
}

model SupplyItem {
  id          Int      @id @default(autoincrement())
  category    String // pixelPet
  rarity      String // common / rare / epic / legendary
  name        String   @unique
  description String?
  imageUrl    String
  unlockHint  String?
  createdAt   DateTime @default(now())
  userCollections UserCollection[]

  @@map("supply_item")
}

model UserCollection {
  id         Int      @id @default(autoincrement())
  userId     String
  itemId     Int
  source     String // freeDraw / paidDraw / share
  obtainedAt DateTime @default(now())
  isEquipped Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       SupplyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, obtainedAt])
  @@map("user_collection")
}

model FocusSession {
  id            Int       @id @default(autoincrement())
  userId        String
  duration      Int       // 30 or 60
  status        String    // active / completed / abandoned / cheated
  startedAt     DateTime
  endedAt       DateTime?
  pointsAwarded Int       @default(0)
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("focus_session")
}
